# ===========================================================================
# Golden State Injury Lawyers — root .htaccess (Apache / Hostinger)
# ===========================================================================

DirectoryIndex index.php index.html
Options -Indexes

# ---- Custom error pages ----------------------------------------------------
ErrorDocument 404 /404.php
ErrorDocument 500 /500.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS (enable in production — has no effect on the local PHP server).
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Canonical host: force non-www.
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # Dynamic XML sitemap.
  RewriteRule ^sitemap\.xml$ sitemap.php [L]

  # (Clean URLs for /practice-areas/ and /blog/ are handled by the .htaccess
  #  files inside those folders.)
</IfModule>

# ---- Security headers ------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # Enable once HTTPS is confirmed working:
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ---- Block access to sensitive files --------------------------------------
<FilesMatch "^\.env$|^config\.php$|composer\.(json|lock)$|\.(sql|log|sh|ini|md)$">
  Require all denied
</FilesMatch>

# ---- Gzip compression ------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2
</IfModule>

# ---- Browser caching -------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  # Images: 1 year
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  # CSS / JS: 1 month
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  # HTML: 1 day
  ExpiresByType text/html "access plus 1 day"
</IfModule>
