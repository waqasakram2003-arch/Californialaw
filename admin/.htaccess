# Admin area protection (Apache / Hostinger).
# PHP login is enforced by admin-bootstrap.php on every page. For an extra
# layer, uncomment and set your office/static IPs below to restrict access.

# <RequireAll>
#   Require ip 203.0.113.0/24
#   Require ip 198.51.100.7
# </RequireAll>

Options -Indexes

# Never serve the admin includes directly.
<FilesMatch "\.(inc)$">
  Require all denied
</FilesMatch>
